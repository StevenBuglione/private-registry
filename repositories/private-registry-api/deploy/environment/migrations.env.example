# One-shot schema-owner task. Never use this role for a long-running service.
SPRING_PROFILES_ACTIVE=
SPRING_MAIN_WEB_APPLICATION_TYPE=none
SPRING_DATASOURCE_URL=jdbc:postgresql://database.example.invalid:5432/registry
SPRING_DATASOURCE_USERNAME=registry_migrator
SPRING_DATASOURCE_PASSWORD=replace-from-secret-store
SPRING_FLYWAY_URL=jdbc:postgresql://database.example.invalid:5432/registry
SPRING_FLYWAY_USER=registry_migrator
SPRING_FLYWAY_PASSWORD=replace-from-secret-store
SPRING_FLYWAY_ENABLED=true
REGISTRY_RUNTIME_EXIT_AFTER_STARTUP=true
REGISTRY_SECURITY_PERMIT_ALL=true
REGISTRY_EVENTING_ENABLED=false
REGISTRY_WEBHOOK_ENABLED=false
REGISTRY_INGESTION_ENABLED=false
