# Public API task. Use the registry_web database role.
SPRING_PROFILES_ACTIVE=
SPRING_DATASOURCE_URL=jdbc:postgresql://database.example.invalid:5432/registry
SPRING_DATASOURCE_USERNAME=registry_web
SPRING_DATASOURCE_PASSWORD=replace-from-secret-store
SPRING_FLYWAY_ENABLED=false
SERVER_PORT=8080

REGISTRY_SECURITY_PERMIT_ALL=false
REGISTRY_ALLOWED_ALB_SIGNER_ARN=arn:aws:elasticloadbalancing:us-east-1:111111111111:loadbalancer/app/example/replace
REGISTRY_ALLOWED_OIDC_CLIENT_ID=replace-with-entra-application-client-id
REGISTRY_ALLOWED_OIDC_ISSUER=https://login.microsoftonline.com/replace-tenant-id/v2.0
AWS_REGION=us-east-1
REGISTRY_GRAPH_ENDPOINT=https://graph.microsoft.com/v1.0/me/checkMemberGroups
REGISTRY_GRAPH_TIMEOUT=5s
REGISTRY_MEMBERSHIP_CACHE_TTL=60s
REGISTRY_ENTRA_APM_GROUPS=APM0000001:replace-group-object-id,APM0000002:replace-group-object-id
REGISTRY_ENTRA_ADMIN_GROUP_ID=replace-admin-group-object-id
REGISTRY_POST_LOGOUT_REDIRECT_URI=/

REGISTRY_ARTIFACTORY_URL=https://your-company.jfrog.io/artifactory
REGISTRY_ARTIFACTORY_ACCESS_TOKEN=replace-from-secret-store
REGISTRY_ARTIFACTORY_MODULE_REPOSITORY=iac-modules-public-remote
REGISTRY_ARTIFACTORY_PROVIDER_REPOSITORY=iac-providers-public-remote
REGISTRY_ARTIFACTORY_CONNECTION_TIMEOUT=3s
REGISTRY_ARTIFACTORY_SOCKET_TIMEOUT=5s

REGISTRY_EVENTING_ENABLED=true
REGISTRY_WEBHOOK_ENABLED=true
REGISTRY_WEBHOOK_SECRET=replace-from-secret-store
REGISTRY_WEBHOOK_ORIGIN=your-company.jfrog.io
REGISTRY_WEBHOOK_SUBSCRIPTION_ID=registry-production
REGISTRY_WEBHOOK_ALLOWED_REPOSITORIES=iac-provider-release-local,iac-module-release-local,iac-catalog-release-local
REGISTRY_WEBHOOK_ALLOWED_PATH_PREFIXES=v1/,hashicorp/,Azure/,registry/
REGISTRY_WEBHOOK_MAXIMUM_PAYLOAD_BYTES=262144
REGISTRY_INGESTION_ENABLED=false
