# Private worker task. It must not be registered with the public load balancer.
SPRING_PROFILES_ACTIVE=
SPRING_MAIN_WEB_APPLICATION_TYPE=none
SPRING_MAIN_KEEP_ALIVE=true
SPRING_DATASOURCE_URL=jdbc:postgresql://database.example.invalid:5432/registry
SPRING_DATASOURCE_USERNAME=registry_indexer
SPRING_DATASOURCE_PASSWORD=replace-from-secret-store
SPRING_FLYWAY_ENABLED=false

REGISTRY_SECURITY_PERMIT_ALL=true
REGISTRY_ARTIFACTORY_URL=https://your-company.jfrog.io/artifactory
REGISTRY_ARTIFACTORY_ACCESS_TOKEN=replace-from-secret-store
REGISTRY_ARTIFACTORY_CONNECTION_TIMEOUT=3s
REGISTRY_ARTIFACTORY_SOCKET_TIMEOUT=5m
REGISTRY_ARTIFACTORY_MODULE_REPOSITORY=iac-modules-public-remote
REGISTRY_ARTIFACTORY_PROVIDER_REPOSITORY=iac-providers-public-remote

REGISTRY_EVENTING_ENABLED=true
REGISTRY_EVENT_POLL_INTERVAL=30s
REGISTRY_EVENT_CLAIM_RECOVERY_DELAY=1m
REGISTRY_EVENT_CLAIM_TIMEOUT=5m
REGISTRY_EVENT_POLL_BATCH_SIZE=25
REGISTRY_EVENT_MAXIMUM_ATTEMPTS=5
REGISTRY_EVENT_COMPLETED_RETENTION=7d
REGISTRY_EVENT_DEAD_LETTER_RETENTION=90d
REGISTRY_EVENTING_RETENTION_CLEANUP_DELAY=24h
REGISTRY_WEBHOOK_ENABLED=false

REGISTRY_INGESTION_ENABLED=true
REGISTRY_GOVERNED_REPOSITORIES=iac-provider-release-local,iac-module-release-local,iac-catalog-release-local
REGISTRY_CATALOG_REPOSITORY=iac-catalog-release-local
REGISTRY_INGESTION_MANIFEST_SUFFIX=catalog-manifest.json
REGISTRY_MAXIMUM_MANIFEST_BYTES=8388608
REGISTRY_MAXIMUM_ARTIFACT_BYTES=536870912
REGISTRY_MAXIMUM_DOCUMENT_BYTES=16777216
REGISTRY_DOCUMENT_INGESTION_CONCURRENCY=8
REGISTRY_RECONCILE_ON_STARTUP=false
REGISTRY_INCREMENTAL_RECONCILIATION_DELAY=15m
REGISTRY_INCREMENTAL_RECONCILIATION_INITIAL_DELAY=15m
REGISTRY_FULL_RECONCILIATION_CRON=0 17 2 * * *
REGISTRY_DOWNLOAD_STATISTICS_DELAY=15m
REGISTRY_DOWNLOAD_STATISTICS_INITIAL_DELAY=30s
REGISTRY_ANALYTICS_CLEANUP_CRON=0 11 3 * * *
