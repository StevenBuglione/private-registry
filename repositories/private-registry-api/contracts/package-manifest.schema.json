{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/contracts/package-manifest.schema.json",
  "title": "Private Registry Package Manifest",
  "description": "Immutable metadata contract published with each promoted module or provider version.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "identity",
    "display",
    "registry",
    "compatibility",
    "source",
    "release"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "kind": {
      "enum": [
        "module",
        "provider"
      ]
    },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "namespace",
        "name",
        "version"
      ],
      "properties": {
        "namespace": {
          "$ref": "#/$defs/slug"
        },
        "name": {
          "$ref": "#/$defs/slug"
        },
        "target": {
          "$ref": "#/$defs/slug"
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
        }
      }
    },
    "display": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "description",
        "keywords",
        "owners",
        "supportLevel",
        "verification",
        "lifecycle",
        "riskTier",
        "visibility"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 140
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        },
        "keywords": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/slug"
          },
          "maxItems": 30
        },
        "owners": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/slug"
          }
        },
        "supportChannel": {
          "type": "string",
          "maxLength": 512
        },
        "supportLevel": {
          "enum": [
            "supported",
            "maintenance",
            "experimental",
            "deprecated",
            "revoked",
            "archived"
          ]
        },
        "verification": {
          "enum": [
            "enterprise-verified",
            "security-reviewed",
            "unverified"
          ]
        },
        "lifecycle": {
          "enum": [
            "draft",
            "candidate",
            "approved",
            "maintenance",
            "deprecated",
            "revoked",
            "archived"
          ]
        },
        "riskTier": {
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "visibility": {
          "enum": [
            "enterprise",
            "restricted"
          ]
        },
        "replacementSource": {
          "type": "string",
          "maxLength": 512
        }
      }
    },
    "registry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hostname",
        "repository",
        "source",
        "artifactPath"
      ],
      "properties": {
        "hostname": {
          "type": "string",
          "minLength": 1
        },
        "repository": {
          "$ref": "#/$defs/slug"
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "artifactPath": {
          "type": "string",
          "minLength": 1
        },
        "consoleUrl": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "terraform"
      ],
      "properties": {
        "terraform": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "commit",
        "tag"
      ],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "commit": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{7,64}$"
        },
        "tag": {
          "type": "string",
          "minLength": 1
        },
        "directory": {
          "type": "string"
        }
      }
    },
    "release": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "publishedAt",
        "packageDigest",
        "documentationPath",
        "documentationDigest"
      ],
      "properties": {
        "publishedAt": {
          "type": "string",
          "format": "date-time"
        },
        "packageDigest": {
          "$ref": "#/$defs/sha256"
        },
        "documentationPath": {
          "type": "string",
          "minLength": 1
        },
        "documentationDigest": {
          "$ref": "#/$defs/sha256"
        },
        "sbomPath": {
          "type": "string"
        },
        "provenancePath": {
          "type": "string"
        },
        "changelogPath": {
          "type": "string"
        }
      }
    },
    "provider": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "platforms",
        "signing"
      ],
      "properties": {
        "platforms": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "os",
              "arch"
            ],
            "properties": {
              "os": {
                "$ref": "#/$defs/slug"
              },
              "arch": {
                "$ref": "#/$defs/slug"
              }
            }
          }
        },
        "signing": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "verified",
            "fingerprint"
          ],
          "properties": {
            "type": {
              "const": "gpg"
            },
            "verified": {
              "const": true
            },
            "fingerprint": {
              "type": "string",
              "pattern": "^[0-9A-Fa-f ]{16,80}$"
            },
            "publicKeyPath": {
              "type": "string"
            }
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "kind": {
            "const": "module"
          }
        }
      },
      "then": {
        "properties": {
          "identity": {
            "required": [
              "target"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "kind": {
            "const": "provider"
          }
        }
      },
      "then": {
        "required": [
          "provider"
        ]
      },
      "else": {
        "not": {
          "required": [
            "provider"
          ]
        }
      }
    }
  ],
  "$defs": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9](?:[a-z0-9_-]{0,62}[a-z0-9])?$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    }
  }
}
