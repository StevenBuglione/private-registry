{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/contracts/packagedeprecated.schema.json",
  "title": "PackageDeprecated",
  "description": "Marks an approved package version or package identity as deprecated while retaining historical documentation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "eventType",
    "eventId",
    "occurredAt",
    "correlationId",
    "producer",
    "detail"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "eventId": {
      "type": "string",
      "format": "uuid"
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time"
    },
    "correlationId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "producer": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "detail": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "namespace",
        "name",
        "version",
        "repository",
        "artifactPath",
        "packageDigest",
        "manifestPath",
        "manifestDigest",
        "sourceCommit",
        "reason",
        "effectiveAt"
      ],
      "properties": {
        "kind": {
          "enum": [
            "module",
            "provider"
          ]
        },
        "namespace": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string"
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "artifactPath": {
          "type": "string",
          "minLength": 1
        },
        "packageDigest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "manifestPath": {
          "type": "string",
          "minLength": 1
        },
        "manifestDigest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "documentationPath": {
          "type": "string"
        },
        "sourceCommit": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{7,64}$"
        },
        "approvalRecordId": {
          "type": "string"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "replacementSource": {
          "type": "string"
        },
        "effectiveAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "eventType": {
      "const": "PackageDeprecated"
    }
  }
}
