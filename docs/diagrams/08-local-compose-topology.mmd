  api -->|"read-only diagnostics through Java client"| jfrog
  indexer -->|"authoritative reconciliation through Java client"| jfrog
  seeder -->|"idempotent creation and uploads through Java client"| jfrog

  api --> health
  indexer --> health
  postgres --> health
  ui --> health
  api --> auth
  seeder --> catalog
  api --> event
  indexer --> event
  developer --> quality

