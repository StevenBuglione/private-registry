flowchart TB
  developer["Developer or receiving coding agent"]

  subgraph inputs["Ignored local configuration"]
    jfrogEnv[".env.artifactory: JPD hostname and token"]
    eventEnv[".env.eventing: HMAC, origin, subscription, repositories"]
    identityEnv[".env.identity-test: real Entra client, groups, and test users"]
    runtimeUi["UI runtime environment and support metadata"]
  end

  subgraph compose["Docker Compose runtime"]
    postgres[("postgres: PostgreSQL only application state")]
    migrate["migrate: Flyway schema-owner job"]
    roleBootstrap["role-bootstrap: local runtime-role passwords"]
    api["api: Spring MVC, OIDC, catalog, admin, webhook, SSE"]
    indexer["indexer: queue worker, reconciliation, JFrog statistics"]
    ui["ui: Nginx and React runtime configuration"]
    seeder["seeder profile: repositories and curated content"]
  end

  subgraph realDependencies["Real external dependencies"]
    entra["Microsoft Entra ID"]
    graphApi["Microsoft Graph"]
    jfrog["Destination JFrog Artifactory"]
  end

  subgraph verification["Acceptance evidence"]
    health["Container and HTTP health"]
    auth["Real APM-A, APM-B, admin, and no-entitlement sessions"]
    catalog["At least governed providers and modules with digest properties"]
    event["Signed event to queue to searchable catalog to SSE"]
    quality["Gradle, UI quality, Compose, Terraform, and secret scans"]
  end

  developer --> jfrogEnv
  developer --> eventEnv
  developer --> identityEnv
  developer --> runtimeUi
  jfrogEnv --> api
