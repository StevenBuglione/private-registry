  jfrogEnv --> seeder
  eventEnv --> api
  identityEnv --> api
  runtimeUi --> ui

  postgres --> migrate --> roleBootstrap
  roleBootstrap --> api
  roleBootstrap --> indexer
  ui --> api
  api --> postgres
